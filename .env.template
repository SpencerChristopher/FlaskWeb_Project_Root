# Web server settings
SECRET_KEY=your-very-secret-and-long-random-key
PORT=5000

# Admin User (for initial setup via script)
# IMPORTANT: Use the create_admin.py script to set this up.
# Do NOT store a plaintext password here long-term.
# Password must meet complexity rules enforced by scripts/utils.py.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=temporary-password-for-setup

# MongoDB
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=change-me-root-password
MONGO_APP_USER=webserver
MONGO_APP_PASSWORD=change-me-app-password
MONGO_APP_DB=appdb
MONGO_TEST_DB=pytest_appdb
# NOTE: URL-encode special characters in username/password.
MONGO_URI=mongodb://webserver:change-me-app-password@mongo:27017/appdb?authSource=appdb

# Logging
LOG_LEVEL=INFO
FLASK_ENV=development

# Gunicorn concurrency (Workers = Processes, Threads = Per-Process)
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30

# MongoDB Timeouts (ms)
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=30000

# Nginx Timeouts (seconds)
NGINX_PROXY_READ_TIMEOUT=40
NGINX_PROXY_SEND_TIMEOUT=40
NGINX_PROXY_CONNECT_TIMEOUT=5

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password

# JWT Cookie Settings
JWT_COOKIE_SECURE=true
JWT_COOKIE_CSRF_PROTECT=true
JWT_COOKIE_SAMESITE=Lax

# CSP Report URI (optional, only needed for report-only mode)
CSP_REPORT_URI=

# Talisman HTTPS redirect (production only)
TALISMAN_FORCE_HTTPS=true

# ProxyFix (trusted proxy hops)
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
PROXY_FIX_X_PREFIX=1

# External APIs (Optional)
KAGGLE_API_KEY=your-kaggle-key
LINKEDIN_API_TOKEN=your-token
LEETCODE_SESSION=your-session
HTB_TOKEN=your-htb-token

# CORS
CORS_ORIGINS=https://localhost,https://127.0.0.1

# --- Cloudflare & Production Edge ---
DOMAIN_NAME=your-site.com
# The Tunnel Token is stored as a secret and injected in prod
CLOUDFLARE_TUNNEL_TOKEN=
