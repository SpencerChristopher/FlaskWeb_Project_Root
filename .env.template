# ==============================================================================
# 1. CORE IDENTITY & SECURITY
# ==============================================================================
# SECRET_KEY: A long, random string. Used for CSRF, sessions, and JWT signing.
SECRET_KEY=your-very-secret-and-long-random-key
PORT=5001

# Admin User (Initial setup only)
# IMPORTANT: Use 'scripts/create_admin.py' to initialize the admin.
# Do NOT store a plaintext password here long-term.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=temporary-password-for-setup

# ==============================================================================
# 2. INFRASTRUCTURE (DATABASE & CACHE)
# ==============================================================================
# MongoDB Credentials
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=change-me-root-password
MONGO_APP_USER=webserver
MONGO_APP_PASSWORD=change-me-app-password
MONGO_APP_DB=appdb
MONGO_TEST_DB=pytest_appdb

# MongoDB Connection (URL-encode special characters in password)
MONGO_URI=mongodb://webserver:change-me-app-password@mongo:27017/appdb?authSource=appdb

# MongoDB Timeouts (ms)
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
MONGO_CONNECT_TIMEOUT_MS=5000
MONGO_SOCKET_TIMEOUT_MS=30000

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change-me-redis-password

# ==============================================================================
# 3. RUNTIME & PERFORMANCE
# ==============================================================================
FLASK_ENV=development
LOG_LEVEL=INFO

# Gunicorn (Concurrency)
GUNICORN_WORKERS=3
GUNICORN_THREADS=2
GUNICORN_TIMEOUT=30

# Nginx Timeouts (seconds)
NGINX_PROXY_READ_TIMEOUT=40
NGINX_PROXY_SEND_TIMEOUT=40
NGINX_PROXY_CONNECT_TIMEOUT=5

# ==============================================================================
# 4. NETWORKING & HTTP SECURITY
# ==============================================================================
# CORS (Comma-separated list)
CORS_ORIGINS=http://localhost:5001,http://127.0.0.1:5001,https://staging.spencerscooking.uk

# Talisman (HTTPS Enforcement)
# Note: Should be 'true' in production/staging environments
TALISMAN_FORCE_HTTPS=false
CSP_REPORT_URI=

# ProxyFix (Trusted hops behind Cloudflare/Nginx)
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
PROXY_FIX_X_PREFIX=1
FORWARDED_ALLOW_IPS=*

# JWT Cookie Settings
JWT_COOKIE_SECURE=true
JWT_COOKIE_CSRF_PROTECT=true
JWT_COOKIE_SAMESITE=Lax

# ==============================================================================
# 5. EXTERNAL INTEGRATIONS & CLOUDFLARE
# ==============================================================================
DOMAIN_NAME=spencercooking.uk

# Cloudflare Tunnel Token (Staging)
STAGING_TOKEN=your-cloudflare-tunnel-token

# Cloudflare Access (E2E Test Bypass)
# Provide Client ID/Secret for Service Tokens OR a direct JWT Assertion
CF_ACCESS_CLIENT_ID=your-client-id
CF_ACCESS_CLIENT_SECRET=your-client-secret
CF_ACCESS_JWT=your-raw-jwt-assertion

# Optional External APIs
KAGGLE_API_KEY=
LINKEDIN_API_TOKEN=
LEETCODE_SESSION=
HTB_TOKEN=
