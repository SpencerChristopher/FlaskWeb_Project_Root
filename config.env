# Non-secret defaults shared across environments.
# Secrets must be injected via GitHub Secrets or local .env.

# Logging
LOG_LEVEL=INFO

# Flask environment
FLASK_ENV=development

# JWT Cookie Settings
JWT_COOKIE_SECURE=true
JWT_COOKIE_CSRF_PROTECT=true
JWT_COOKIE_SAMESITE=Lax

# ProxyFix (trusted proxy hops)
PROXY_FIX_X_FOR=1
PROXY_FIX_X_PROTO=1
PROXY_FIX_X_HOST=1
PROXY_FIX_X_PREFIX=1

# CORS
CORS_ORIGINS=https://localhost,https://127.0.0.1

# Gunicorn timeout (seconds)
GUNICORN_TIMEOUT=30
FORWARDED_ALLOW_IPS=*

# Mongo timeouts (milliseconds)
MONGO_SERVER_SELECTION_TIMEOUT_MS=10000
MONGO_CONNECT_TIMEOUT_MS=10000
MONGO_SOCKET_TIMEOUT_MS=10000

# CSP Report URI (optional)
CSP_REPORT_URI=

# Talisman HTTPS redirect (production only)
TALISMAN_FORCE_HTTPS=true
